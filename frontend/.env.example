# Copy to .env.local and fill in real values (see Supabase dashboard → Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Observability (optional — leave blank to disable; the app runs unchanged) ──
# These are build-time inlined, so rebuild after changing them.
NEXT_PUBLIC_POSTHOG_KEY=                    # PostHog project key ("phc_..."); blank = off
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=                     # Sentry DSN; blank = off
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
